#: custom-poll-system.php:도움말
msgid "How to use Shortcode"
msgstr "1. 설문 숏코드 사용법"

msgid "Copy and paste the shortcode below into your page or post."
msgstr "생성한 설문조사를 페이지나 포스트에 삽입하려면 아래의 숏코드를 복사하여 붙여넣으세요."

msgid "Poll ID"
msgstr "설문ID"

msgid "You can find the Poll ID in the %s menu."
msgstr "설문 ID는 %s 메뉴에서 확인하실 수 있습니다."

msgid "Plugin Author Information"
msgstr "2. 플러그인 제작자 정보"

msgid "This plugin was produced by %s."
msgstr "본 플러그인은 %s에서 제작되었습니다."

msgid "Official Website"
msgstr "공식 홈페이지"

